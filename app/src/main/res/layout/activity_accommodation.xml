<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F5FBFF"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|end">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Verified Inns"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#262626"
                android:gravity="start" />

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_round"
                android:drawableLeft="@drawable/ic_filter"
                android:padding="8dp"
                android:text="Filters"
                android:textColor="#000"
                android:textSize="12sp"
                app:backgroundTint="@null" />

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_round"
                app:backgroundTint="@null"
                android:text="Wishlist"
                android:textColor="#000"
                android:drawableLeft="@drawable/ic_heart"
                android:padding="8dp"
                android:textSize="12sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Hotel Card 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="14dp">

                <!-- Hotel Image -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_img_rounded"
                        android:scaleType="centerCrop"
                        android:src="@drawable/hotel_img_1" />

                    <!-- Wishlist icon over image -->
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_white_circle"
                        android:src="@drawable/ic_heart" />

                    <!-- Discount label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="8dp"
                        android:background="@drawable/rounded_green_bg"
                        android:paddingStart="10dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="2dp"
                        android:text="15% OFF"
                        android:textColor="#fff"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Hotel Detail Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingLeft="13dp">

                    <!-- Top row: Hotel name + stars -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Grand Palace Hotel"
                            android:textColor="#222"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_star" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_star" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_star" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_star" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_star" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Location -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_location" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="3dp"
                            android:text="Mumbai, Maharashtra"
                            android:textColor="#888"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Rating -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_rating"
                            android:paddingLeft="6dp"
                            android:paddingTop="2dp"
                            android:paddingRight="6dp"
                            android:paddingBottom="2dp"
                            android:text="4.5"
                            android:textColor="#15B374"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="7dp"
                            android:text="Excellent"
                            android:textColor="#15B374"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Description -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="Luxury 5-star hotel in the heart of Mumbai with world-class amenities and service."
                        android:textColor="#595f6b"
                        android:textSize="13sp" />

                    <!-- Facilities -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="Wi-Fi"
                                android:textColor="#444"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="Parking"
                                android:textColor="#444"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="Pool"
                                android:textColor="#444"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="Breakfast"
                                android:textColor="#444"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="Gym"
                                android:textColor="#444"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="Spa"
                                android:textColor="#444"
                                android:textSize="12sp" />

                            <TextView
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="+1 more"
                                android:textColor="#444"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <!-- Price row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="7dp"
                            android:text="₹8,500"
                            android:textColor="#15B374"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="0dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="per night • includes taxes"
                            android:textColor="#888"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginLeft="5dp"
                            android:text="View Details"
                            android:textColor="#444"
                            android:textSize="13sp"
                            app:backgroundTint="@android:color/white"
                            app:cornerRadius="12dp"
                            app:strokeColor="#CCCCCC"
                            app:strokeWidth="1dp" />

                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginLeft="5dp"
                            android:text="Book Now"
                            android:textColor="#fff"
                            android:textSize="13sp"
                            app:backgroundTint="#1A1A1A"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Hotel Card 2: Boutique Stay Delhi  -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="14dp">

                <!-- Hotel Image -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_img_rounded"
                        android:scaleType="centerCrop"
                        android:src="@drawable/hotel_img_2" />

                    <!-- Discount label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="8dp"
                        android:background="@drawable/rounded_green_bg"
                        android:paddingStart="10dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="2dp"
                        android:text="12% OFF"
                        android:textColor="#fff"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- Wishlist icon over image -->
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_white_circle"
                        android:src="@drawable/ic_heart" />
                </FrameLayout>

                <!-- Hotel Detail Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingLeft="13dp">

                    <!-- Top row: Hotel name + stars -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Boutique Stay Delhi"
                            android:textColor="#222"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_star" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_star" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_star" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_star" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_star_half" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Location -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_location" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="3dp"
                            android:text="New Delhi, Delhi"
                            android:textColor="#888"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Rating -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_rating"
                            android:paddingLeft="6dp"
                            android:paddingTop="2dp"
                            android:paddingRight="6dp"
                            android:paddingBottom="2dp"
                            android:text="4.2"
                            android:textColor="#15B374"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="7dp"
                            android:text="Very Good"
                            android:textColor="#15B374"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Description -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="Charming boutique hotel with personalized service and modern amenities."
                        android:textColor="#595f6b"
                        android:textSize="13sp" />

                    <!-- Facilities -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="Wi-Fi"
                                android:textColor="#444"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="Breakfast"
                                android:textColor="#444"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="Pet-friendly"
                                android:textColor="#444"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="Restaurant"
                                android:textColor="#444"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/bg_tag"
                                android:padding="7dp"
                                android:text="Bar"
                                android:textColor="#444"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <!-- Price row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="7dp"
                            android:text="₹4,500"
                            android:textColor="#15B374"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="0dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="per night • includes taxes"
                            android:textColor="#888"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:text="View Details"
                            android:textColor="#444"
                            android:textSize="13sp"
                            app:backgroundTint="@android:color/white"
                            app:cornerRadius="12dp"
                            app:strokeColor="#CCCCCC"
                            app:strokeWidth="1dp" />

                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginLeft="5dp"
                            android:text="Book Now"
                            android:textColor="#fff"
                            android:textSize="13sp"
                            app:backgroundTint="#1A1A1A"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
